{
  "meta": {
    "sourceDb": "SQLSERVER",
    "targetDb": "DAMENG",
    "version": "1.0.0",
    "description": "SQL Server 到达梦 DM8 迁移兼容性规则集 — T-SQL → DMSQL 转换",
    "author": "DMA Team"
  },
  "rules": [
    {"code":"S2DM-FN-001","name":"ISNULL → NVL","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"ISNULL(${expr}, ${replacement})","replacementPattern":"NVL(${expr}, ${replacement})","description":"T-SQL ISNULL 替换为达梦 NVL","exampleSqlSource":"SELECT ISNULL(name, 'N/A') FROM users;","exampleSqlTarget":"SELECT NVL(name, 'N/A') FROM users;"},
    {"code":"S2DM-FN-002","name":"GETDATE → SYSDATE","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"GETDATE()","replacementPattern":"SYSDATE","description":"T-SQL GETDATE() 替换为 SYSDATE","exampleSqlSource":"SELECT GETDATE();","exampleSqlTarget":"SELECT SYSDATE;"},
    {"code":"S2DM-FN-003","name":"DATEADD → DATEADD/计算","category":"BUILTIN_FUNCTION","severity":"WARNING","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"DATEADD(${unit}, ${n}, ${date})","replacementPattern":"DATEADD(${unit}, ${n}, ${date})","description":"达梦支持 DATEADD，但 unit 参数格式不同(day→DD)","exampleSqlSource":"SELECT DATEADD(day, 7, GETDATE());","exampleSqlTarget":"SELECT DATEADD(DD, 7, SYSDATE);"},
    {"code":"S2DM-FN-004","name":"DATEDIFF → DATEDIFF","category":"BUILTIN_FUNCTION","severity":"WARNING","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"DATEDIFF(${unit}, ${d1}, ${d2})","replacementPattern":"DATEDIFF(${unit}, ${d1}, ${d2})","description":"达梦支持 DATEDIFF，但 unit 参数格式不同","exampleSqlSource":"SELECT DATEDIFF(day, '2024-01-01', '2024-12-31');","exampleSqlTarget":"SELECT DATEDIFF(DD, '2024-01-01', '2024-12-31');"},
    {"code":"S2DM-FN-005","name":"CHARINDEX → INSTR","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"CHARINDEX(${substr}, ${str})","replacementPattern":"INSTR(${str}, ${substr})","description":"T-SQL CHARINDEX 替换为 INSTR（参数顺序相反）","exampleSqlSource":"SELECT CHARINDEX('a', name) FROM users;","exampleSqlTarget":"SELECT INSTR(name, 'a') FROM users;"},
    {"code":"S2DM-FN-006","name":"LEN → LENGTH","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"LEN(${str})","replacementPattern":"LENGTH(${str})","description":"T-SQL LEN 替换为 LENGTH","exampleSqlSource":"SELECT LEN(name) FROM users;","exampleSqlTarget":"SELECT LENGTH(name) FROM users;"},
    {"code":"S2DM-FN-007","name":"CONCAT 兼容","category":"BUILTIN_FUNCTION","severity":"WARNING","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"CONCAT(${a}, ${b}, ${c})","replacementPattern":"CONCAT(CONCAT(${a}, ${b}), ${c})","description":"达梦 CONCAT 仅支持两个参数，需嵌套","exampleSqlSource":"SELECT CONCAT(a, b, c) FROM t;","exampleSqlTarget":"SELECT CONCAT(CONCAT(a, b), c) FROM t;"},
    {"code":"S2DM-SYN-001","name":"TOP → LIMIT","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"SELECT TOP ${n}","replacementPattern":"","description":"T-SQL SELECT TOP n 替换为 LIMIT n","exampleSqlSource":"SELECT TOP 10 * FROM users;","exampleSqlTarget":"SELECT * FROM users LIMIT 10;"},
    {"code":"S2DM-SYN-002","name":"方括号 → 双引号/移除","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"[","replacementPattern":"\"","description":"T-SQL 方括号 [identifier] 替换为达梦双引号","exampleSqlSource":"SELECT [id], [name] FROM [users];","exampleSqlTarget":"SELECT \"id\", \"name\" FROM \"users\";"},
    {"code":"S2DM-SYN-003","name":"OFFSET FETCH → LIMIT OFFSET","category":"SYNTAX","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"OFFSET ${n} ROWS FETCH NEXT ${m} ROWS ONLY","replacementPattern":"LIMIT ${m} OFFSET ${n}","description":"T-SQL OFFSET-FETCH 替换为 LIMIT-OFFSET","exampleSqlSource":"SELECT * FROM users ORDER BY id OFFSET 10 ROWS FETCH NEXT 20 ROWS ONLY;","exampleSqlTarget":"SELECT * FROM users ORDER BY id LIMIT 20 OFFSET 10;"},
    {"code":"S2DM-SYN-004","name":"+ 字符串拼接 → CONCAT/||","category":"SYNTAX","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"${a} + ${b}","replacementPattern":"","description":"T-SQL 用 + 拼接字符串，达梦用 CONCAT 或 ||","exampleSqlSource":"SELECT first_name + ' ' + last_name FROM users;","exampleSqlTarget":"SELECT first_name || ' ' || last_name FROM users;"},
    {"code":"S2DM-DT-001","name":"NVARCHAR → NVARCHAR2","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"NVARCHAR","replacementPattern":"NVARCHAR2","description":"T-SQL NVARCHAR 替换为 NVARCHAR2","exampleSqlSource":"CREATE TABLE t (name NVARCHAR(100));","exampleSqlTarget":"CREATE TABLE t (name NVARCHAR2(100));"},
    {"code":"S2DM-DT-002","name":"DATETIME2 → TIMESTAMP","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"DATETIME2","replacementPattern":"TIMESTAMP","description":"T-SQL DATETIME2 替换为 TIMESTAMP","exampleSqlSource":"CREATE TABLE t (created DATETIME2);","exampleSqlTarget":"CREATE TABLE t (created TIMESTAMP);"},
    {"code":"S2DM-DT-003","name":"BIT → SMALLINT","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"BIT","replacementPattern":"SMALLINT","description":"T-SQL BIT 替换为 SMALLINT","exampleSqlSource":"CREATE TABLE t (active BIT);","exampleSqlTarget":"CREATE TABLE t (active SMALLINT);"},
    {"code":"S2DM-DT-004","name":"UNIQUEIDENTIFIER → VARCHAR(36)","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"UNIQUEIDENTIFIER","replacementPattern":"VARCHAR(36)","description":"T-SQL UNIQUEIDENTIFIER 替换为 VARCHAR(36)","exampleSqlSource":"CREATE TABLE t (uid UNIQUEIDENTIFIER);","exampleSqlTarget":"CREATE TABLE t (uid VARCHAR(36));"},
    {"code":"S2DM-DDL-001","name":"IDENTITY → IDENTITY","category":"DDL","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"IDENTITY(${seed}, ${inc})","replacementPattern":"IDENTITY(${seed}, ${inc})","description":"达梦支持 IDENTITY 列，语法略有不同","exampleSqlSource":"CREATE TABLE t (id INT IDENTITY(1,1) PRIMARY KEY);","exampleSqlTarget":"CREATE TABLE t (id INT IDENTITY(1,1) PRIMARY KEY);"},
    {"code":"S2DM-DDL-002","name":"SCHEMA 概念差异","category":"DDL","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"DAMENG","matchPattern":"CREATE SCHEMA","replacementPattern":"CREATE SCHEMA","description":"SQL Server schema=namespace, 达梦 schema=user, 需调整组织方式","exampleSqlSource":"CREATE SCHEMA sales;","exampleSqlTarget":"CREATE SCHEMA sales;"}
  ]
}
