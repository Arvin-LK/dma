{
  "meta": {
    "sourceDb": "SQLSERVER",
    "targetDb": "OCEANBASE",
    "version": "1.0.0",
    "description": "SQL Server 到 OceanBase (MySQL 模式) 迁移兼容性规则集 — T-SQL → MySQL 语法",
    "author": "DMA Team"
  },
  "rules": [
    {"code":"S2OB-FN-001","name":"ISNULL → IFNULL","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"ISNULL(${expr}, ${replacement})","replacementPattern":"IFNULL(${expr}, ${replacement})","description":"T-SQL ISNULL 替换为 IFNULL","exampleSqlSource":"SELECT ISNULL(name, 'N/A') FROM users;","exampleSqlTarget":"SELECT IFNULL(name, 'N/A') FROM users;"},
    {"code":"S2OB-FN-002","name":"GETDATE → NOW","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"GETDATE()","replacementPattern":"NOW()","description":"T-SQL GETDATE() 替换为 NOW()","exampleSqlSource":"SELECT GETDATE();","exampleSqlTarget":"SELECT NOW();"},
    {"code":"S2OB-FN-003","name":"CHARINDEX → LOCATE","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"CHARINDEX(${substr}, ${str})","replacementPattern":"LOCATE(${substr}, ${str})","description":"T-SQL CHARINDEX 替换为 LOCATE（参数顺序相同）","exampleSqlSource":"SELECT CHARINDEX('a', name) FROM users;","exampleSqlTarget":"SELECT LOCATE('a', name) FROM users;"},
    {"code":"S2OB-FN-004","name":"DATEADD → DATE_ADD","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"DATEADD(${unit}, ${n}, ${date})","replacementPattern":"DATE_ADD(${date}, INTERVAL ${n} ${unit})","description":"T-SQL DATEADD 替换为 DATE_ADD","exampleSqlSource":"SELECT DATEADD(day, 7, GETDATE());","exampleSqlTarget":"SELECT DATE_ADD(NOW(), INTERVAL 7 DAY);"},
    {"code":"S2OB-FN-005","name":"LEN → LENGTH","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"LEN(${str})","replacementPattern":"LENGTH(${str})","description":"T-SQL LEN 替换为 LENGTH","exampleSqlSource":"SELECT LEN(name) FROM users;","exampleSqlTarget":"SELECT LENGTH(name) FROM users;"},
    {"code":"S2OB-SYN-001","name":"TOP → LIMIT","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"SELECT TOP ${n}","replacementPattern":"","description":"T-SQL SELECT TOP n → LIMIT n","exampleSqlSource":"SELECT TOP 10 * FROM users;","exampleSqlTarget":"SELECT * FROM users LIMIT 10;"},
    {"code":"S2OB-SYN-002","name":"方括号 → 反引号","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"[","replacementPattern":"`","description":"T-SQL 方括号替换为 MySQL 反引号","exampleSqlSource":"SELECT [id], [name] FROM [users];","exampleSqlTarget":"SELECT `id`, `name` FROM `users`;"},
    {"code":"S2OB-SYN-003","name":"+ 拼接 → CONCAT","category":"SYNTAX","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"${a} + ${b}","replacementPattern":"","description":"T-SQL 字符串拼接 + 替换为 CONCAT()","exampleSqlSource":"SELECT first_name + ' ' + last_name FROM users;","exampleSqlTarget":"SELECT CONCAT(first_name, ' ', last_name) FROM users;"},
    {"code":"S2OB-DT-001","name":"NVARCHAR → VARCHAR","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"NVARCHAR","replacementPattern":"VARCHAR","description":"T-SQL NVARCHAR 替换为 VARCHAR（OceanBase 默认 UTF-8）","exampleSqlSource":"CREATE TABLE t (name NVARCHAR(100));","exampleSqlTarget":"CREATE TABLE t (name VARCHAR(100));"},
    {"code":"S2OB-DT-002","name":"IDENTITY → AUTO_INCREMENT","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"IDENTITY(${seed}, ${inc})","replacementPattern":"AUTO_INCREMENT","description":"T-SQL IDENTITY 替换为 AUTO_INCREMENT","exampleSqlSource":"CREATE TABLE t (id INT IDENTITY(1,1) PRIMARY KEY);","exampleSqlTarget":"CREATE TABLE t (id INT AUTO_INCREMENT PRIMARY KEY);"},
    {"code":"S2OB-DT-003","name":"BIT → TINYINT","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"BIT","replacementPattern":"TINYINT(1)","description":"T-SQL BIT 替换为 TINYINT(1)","exampleSqlSource":"CREATE TABLE t (active BIT);","exampleSqlTarget":"CREATE TABLE t (active TINYINT(1));"},
    {"code":"S2OB-DDL-001","name":"SCHEMA → DATABASE","category":"DDL","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"OCEANBASE","matchPattern":"CREATE SCHEMA","replacementPattern":"CREATE DATABASE","description":"SQL Server SCHEMA 概念对应 OceanBase DATABASE","exampleSqlSource":"CREATE SCHEMA sales;","exampleSqlTarget":"CREATE DATABASE sales;"}
  ]
}
