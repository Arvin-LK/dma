{
  "meta": {
    "sourceDb": "SQLSERVER",
    "targetDb": "GAUSSDB",
    "version": "1.0.0",
    "description": "SQL Server 到 GaussDB 迁移兼容性规则集 — T-SQL → GaussDB (PG兼容) 转换",
    "author": "DMA Team"
  },
  "rules": [
    {"code":"S2GD-FN-001","name":"ISNULL → COALESCE","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"ISNULL(${expr}, ${replacement})","replacementPattern":"COALESCE(${expr}, ${replacement})","description":"T-SQL ISNULL 替换为 COALESCE","exampleSqlSource":"SELECT ISNULL(name, 'N/A') FROM users;","exampleSqlTarget":"SELECT COALESCE(name, 'N/A') FROM users;"},
    {"code":"S2GD-FN-002","name":"GETDATE() → CURRENT_TIMESTAMP","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"GETDATE()","replacementPattern":"CURRENT_TIMESTAMP","description":"T-SQL GETDATE() 替换为 CURRENT_TIMESTAMP","exampleSqlSource":"SELECT GETDATE();","exampleSqlTarget":"SELECT CURRENT_TIMESTAMP;"},
    {"code":"S2GD-FN-003","name":"DATEADD → 计算表达式","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"DATEADD(${unit}, ${n}, ${date})","replacementPattern":"${date} + INTERVAL '${n} ${unit}'","description":"T-SQL DATEADD 替换为 INTERVAL 计算","exampleSqlSource":"SELECT DATEADD(day, 7, GETDATE());","exampleSqlTarget":"SELECT CURRENT_TIMESTAMP + INTERVAL '7 days';"},
    {"code":"S2GD-FN-004","name":"CHARINDEX → POSITION","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"CHARINDEX(${substr}, ${str})","replacementPattern":"POSITION(${substr} IN ${str})","description":"T-SQL CHARINDEX 替换为 POSITION","exampleSqlSource":"SELECT CHARINDEX('a', name) FROM users;","exampleSqlTarget":"SELECT POSITION('a' IN name) FROM users;"},
    {"code":"S2GD-FN-005","name":"LEN → LENGTH","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"LEN(${str})","replacementPattern":"LENGTH(${str})","description":"T-SQL LEN 替换为 LENGTH","exampleSqlSource":"SELECT LEN(name) FROM users;","exampleSqlTarget":"SELECT LENGTH(name) FROM users;"},
    {"code":"S2GD-FN-006","name":"STUFF → OVERLAY","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"STUFF(${str}, ${start}, ${len}, ${replace})","replacementPattern":"OVERLAY(${str} PLACING ${replace} FROM ${start} FOR ${len})","description":"T-SQL STUFF 替换为 OVERLAY","exampleSqlSource":"SELECT STUFF('hello', 2, 3, 'abc');","exampleSqlTarget":"SELECT OVERLAY('hello' PLACING 'abc' FROM 2 FOR 3);"},
    {"code":"S2GD-SYN-001","name":"TOP → LIMIT","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"SELECT TOP ${n}","replacementPattern":"","description":"T-SQL SELECT TOP n → LIMIT n","exampleSqlSource":"SELECT TOP 10 * FROM users;","exampleSqlTarget":"SELECT * FROM users LIMIT 10;"},
    {"code":"S2GD-SYN-002","name":"方括号 → 双引号","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"[","replacementPattern":"\"","description":"T-SQL 方括号标识符替换为双引号","exampleSqlSource":"SELECT [id], [name] FROM [users];","exampleSqlTarget":"SELECT \"id\", \"name\" FROM \"users\";"},
    {"code":"S2GD-SYN-003","name":"+ 字符串拼接 → ||","category":"SYNTAX","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"${a} + ${b}","replacementPattern":"","description":"T-SQL 字符串 + 拼接替换为 ||","exampleSqlSource":"SELECT first_name + ' ' + last_name FROM users;","exampleSqlTarget":"SELECT first_name || ' ' || last_name FROM users;"},
    {"code":"S2GD-SYN-004","name":"WITH (NOLOCK) → 移除","category":"SYNTAX","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"WITH (NOLOCK)","replacementPattern":"","description":"T-SQL NOLOCK 提示 GaussDB 不支持，需移除","exampleSqlSource":"SELECT * FROM users WITH (NOLOCK);","exampleSqlTarget":"SELECT * FROM users;"},
    {"code":"S2GD-SYN-005","name":"OUTPUT 子句 → RETURNING","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"OUTPUT INSERTED.${col}","replacementPattern":"RETURNING ${col}","description":"T-SQL OUTPUT 子句替换为 RETURNING","exampleSqlSource":"INSERT INTO t (name) OUTPUT INSERTED.id VALUES ('Alice');","exampleSqlTarget":"INSERT INTO t (name) VALUES ('Alice') RETURNING id;"},
    {"code":"S2GD-DT-001","name":"NVARCHAR → VARCHAR","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"NVARCHAR","replacementPattern":"VARCHAR","description":"T-SQL NVARCHAR 替换为 VARCHAR（GaussDB 默认 UTF-8）","exampleSqlSource":"CREATE TABLE t (name NVARCHAR(100));","exampleSqlTarget":"CREATE TABLE t (name VARCHAR(100));"},
    {"code":"S2GD-DT-002","name":"DATETIME2 → TIMESTAMP","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"DATETIME2","replacementPattern":"TIMESTAMP","description":"T-SQL DATETIME2 替换为 TIMESTAMP","exampleSqlSource":"CREATE TABLE t (created DATETIME2);","exampleSqlTarget":"CREATE TABLE t (created TIMESTAMP);"},
    {"code":"S2GD-DT-003","name":"BIT → BOOLEAN","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"BIT","replacementPattern":"BOOLEAN","description":"T-SQL BIT 替换为 BOOLEAN","exampleSqlSource":"CREATE TABLE t (active BIT);","exampleSqlTarget":"CREATE TABLE t (active BOOLEAN);"},
    {"code":"S2GD-DT-004","name":"IDENTITY → SERIAL/BIGSERIAL","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"IDENTITY(${seed}, ${inc})","replacementPattern":"SERIAL","description":"T-SQL IDENTITY 替换为 SERIAL","exampleSqlSource":"CREATE TABLE t (id INT IDENTITY(1,1) PRIMARY KEY);","exampleSqlTarget":"CREATE TABLE t (id SERIAL PRIMARY KEY);"},
    {"code":"S2GD-DT-005","name":"MONEY → DECIMAL(19,4)","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"MONEY","replacementPattern":"DECIMAL(19,4)","description":"T-SQL MONEY 替换为 DECIMAL(19,4)","exampleSqlSource":"CREATE TABLE t (price MONEY);","exampleSqlTarget":"CREATE TABLE t (price DECIMAL(19,4));"},
    {"code":"S2GD-DDL-001","name":"CREATE SCHEMA 差异","category":"DDL","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"CREATE SCHEMA","replacementPattern":"CREATE SCHEMA","description":"SQL Server schema 概念与 GaussDB 不同，需调整命名","exampleSqlSource":"CREATE SCHEMA sales;","exampleSqlTarget":"CREATE SCHEMA sales;"},
    {"code":"S2GD-PL-001","name":"T-SQL → PL/pgSQL","category":"DDL","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GAUSSDB","matchPattern":"CREATE PROCEDURE","replacementPattern":"CREATE OR REPLACE PROCEDURE","description":"T-SQL 存储过程需重写为 GaussDB PL/pgSQL","exampleSqlSource":"CREATE PROCEDURE p1 AS BEGIN SELECT 1; END;","exampleSqlTarget":"CREATE OR REPLACE PROCEDURE p1() AS $$ BEGIN SELECT 1; END; $$ LANGUAGE plpgsql;"}
  ]
}
