{
  "meta": {
    "sourceDb": "SQLSERVER",
    "targetDb": "GOLDENDB",
    "version": "1.0.0",
    "description": "SQL Server 到 GoldenDB 迁移兼容性规则集 — T-SQL → MySQL 兼容语法",
    "author": "DMA Team"
  },
  "rules": [
    {"code":"S2GD2-FN-001","name":"ISNULL → IFNULL","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"ISNULL(${expr}, ${replacement})","replacementPattern":"IFNULL(${expr}, ${replacement})","description":"T-SQL ISNULL 替换为 IFNULL","exampleSqlSource":"SELECT ISNULL(name, 'N/A') FROM users;","exampleSqlTarget":"SELECT IFNULL(name, 'N/A') FROM users;"},
    {"code":"S2GD2-FN-002","name":"GETDATE → NOW","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"GETDATE()","replacementPattern":"NOW()","description":"T-SQL GETDATE() 替换为 NOW()","exampleSqlSource":"SELECT GETDATE();","exampleSqlTarget":"SELECT NOW();"},
    {"code":"S2GD2-FN-003","name":"CHARINDEX → LOCATE","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"CHARINDEX(${substr}, ${str})","replacementPattern":"LOCATE(${substr}, ${str})","description":"T-SQL CHARINDEX 替换为 LOCATE","exampleSqlSource":"SELECT CHARINDEX('a', name) FROM users;","exampleSqlTarget":"SELECT LOCATE('a', name) FROM users;"},
    {"code":"S2GD2-FN-004","name":"DATEADD → DATE_ADD","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"DATEADD(${unit}, ${n}, ${date})","replacementPattern":"DATE_ADD(${date}, INTERVAL ${n} ${unit})","description":"T-SQL DATEADD 替换为 DATE_ADD","exampleSqlSource":"SELECT DATEADD(day, 7, GETDATE());","exampleSqlTarget":"SELECT DATE_ADD(NOW(), INTERVAL 7 DAY);"},
    {"code":"S2GD2-FN-005","name":"LEN → LENGTH","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"LEN(${str})","replacementPattern":"LENGTH(${str})","description":"T-SQL LEN 替换为 LENGTH","exampleSqlSource":"SELECT LEN(name) FROM users;","exampleSqlTarget":"SELECT LENGTH(name) FROM users;"},
    {"code":"S2GD2-SYN-001","name":"TOP → LIMIT","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"SELECT TOP ${n}","replacementPattern":"","description":"T-SQL TOP → LIMIT","exampleSqlSource":"SELECT TOP 10 * FROM users;","exampleSqlTarget":"SELECT * FROM users LIMIT 10;"},
    {"code":"S2GD2-SYN-002","name":"方括号 → 反引号","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"[","replacementPattern":"`","description":"T-SQL 方括号替换为反引号","exampleSqlSource":"SELECT [id], [name] FROM [users];","exampleSqlTarget":"SELECT `id`, `name` FROM `users`;"},
    {"code":"S2GD2-SYN-003","name":"WITH (NOLOCK) → 移除","category":"SYNTAX","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"WITH (NOLOCK)","replacementPattern":"","description":"GoldenDB 不支持 NOLOCK 提示","exampleSqlSource":"SELECT * FROM users WITH (NOLOCK);","exampleSqlTarget":"SELECT * FROM users;"},
    {"code":"S2GD2-DT-001","name":"NVARCHAR → VARCHAR","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"NVARCHAR","replacementPattern":"VARCHAR","description":"T-SQL NVARCHAR 替换为 VARCHAR","exampleSqlSource":"CREATE TABLE t (name NVARCHAR(100));","exampleSqlTarget":"CREATE TABLE t (name VARCHAR(100));"},
    {"code":"S2GD2-DT-002","name":"IDENTITY → AUTO_INCREMENT","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"IDENTITY(${seed}, ${inc})","replacementPattern":"AUTO_INCREMENT","description":"T-SQL IDENTITY 替换为 AUTO_INCREMENT","exampleSqlSource":"CREATE TABLE t (id INT IDENTITY(1,1) PRIMARY KEY);","exampleSqlTarget":"CREATE TABLE t (id INT AUTO_INCREMENT PRIMARY KEY);"},
    {"code":"S2GD2-DT-003","name":"BIT → TINYINT","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"BIT","replacementPattern":"TINYINT(1)","description":"T-SQL BIT 替换为 TINYINT(1)","exampleSqlSource":"CREATE TABLE t (active BIT);","exampleSqlTarget":"CREATE TABLE t (active TINYINT(1));"},
    {"code":"S2GD2-DT-004","name":"DATETIME2 → DATETIME","category":"DATATYPE","severity":"WARNING","patternType":"DATATYPE","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"DATETIME2","replacementPattern":"DATETIME(3)","description":"T-SQL DATETIME2 替换为 DATETIME(3)","exampleSqlSource":"CREATE TABLE t (created DATETIME2);","exampleSqlTarget":"CREATE TABLE t (created DATETIME(3));"},
    {"code":"S2GD2-DDL-001","name":"SCHEMA → DATABASE","category":"DDL","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"SQLSERVER","targetDbType":"GOLDENDB","matchPattern":"CREATE SCHEMA","replacementPattern":"CREATE DATABASE","description":"GoldenDB 建议用 DATABASE 替代 SCHEMA","exampleSqlSource":"CREATE SCHEMA sales;","exampleSqlTarget":"CREATE DATABASE sales;"}
  ]
}
