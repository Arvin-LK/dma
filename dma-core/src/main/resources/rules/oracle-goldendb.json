{
  "meta": {
    "sourceDb": "ORACLE",
    "targetDb": "GOLDENDB",
    "version": "1.0.0",
    "description": "Oracle 到 GoldenDB 迁移兼容性规则集 — Oracle PL/SQL → GoldenDB MySQL 语法转换",
    "author": "DMA Team"
  },
  "rules": [
    {"code":"O2GD2-FN-001","name":"NVL → IFNULL","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"NVL(${expr1}, ${expr2})","replacementPattern":"IFNULL(${expr1}, ${expr2})","description":"Oracle NVL 替换为 GoldenDB IFNULL","exampleSqlSource":"SELECT NVL(name, 'N/A') FROM users;","exampleSqlTarget":"SELECT IFNULL(name, 'N/A') FROM users;"},
    {"code":"O2GD2-FN-002","name":"DECODE → CASE WHEN","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"DECODE(${expr}, ${search}, ${result})","replacementPattern":"CASE WHEN ${expr}=${search} THEN ${result} END","description":"Oracle DECODE 替换为 CASE WHEN","exampleSqlSource":"SELECT DECODE(status, 1, 'Active', 'Inactive') FROM users;","exampleSqlTarget":"SELECT CASE WHEN status=1 THEN 'Active' ELSE 'Inactive' END FROM users;"},
    {"code":"O2GD2-FN-003","name":"SYSDATE → NOW()","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"SYSDATE","replacementPattern":"NOW()","description":"Oracle SYSDATE 替换为 GoldenDB NOW()","exampleSqlSource":"SELECT SYSDATE FROM dual;","exampleSqlTarget":"SELECT NOW();"},
    {"code":"O2GD2-FN-004","name":"TO_CHAR → DATE_FORMAT","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"TO_CHAR(${date}, ${fmt})","replacementPattern":"DATE_FORMAT(${date}, ${fmt})","description":"Oracle TO_CHAR(日期) 替换为 DATE_FORMAT，格式码需转换","exampleSqlSource":"SELECT TO_CHAR(SYSDATE, 'YYYY-MM-DD') FROM dual;","exampleSqlTarget":"SELECT DATE_FORMAT(NOW(), '%Y-%m-%d');"},
    {"code":"O2GD2-FN-005","name":"TO_DATE → STR_TO_DATE","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"TO_DATE(${str}, ${fmt})","replacementPattern":"STR_TO_DATE(${str}, ${fmt})","description":"Oracle TO_DATE 替换为 STR_TO_DATE","exampleSqlSource":"SELECT TO_DATE('2024-01-01', 'YYYY-MM-DD') FROM dual;","exampleSqlTarget":"SELECT STR_TO_DATE('2024-01-01', '%Y-%m-%d');"},
    {"code":"O2GD2-FN-006","name":"TRUNC → DATE/DATE_FORMAT","category":"BUILTIN_FUNCTION","severity":"ERROR","patternType":"FUNCTION","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"TRUNC(${date})","replacementPattern":"DATE(${date})","description":"Oracle TRUNC(日期) 替换为 DATE()","exampleSqlSource":"SELECT TRUNC(SYSDATE) FROM dual;","exampleSqlTarget":"SELECT DATE(NOW());"},
    {"code":"O2GD2-SYN-001","name":"ROWNUM → LIMIT","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"ROWNUM","replacementPattern":"","description":"Oracle ROWNUM 替换为 LIMIT","exampleSqlSource":"SELECT * FROM users WHERE ROWNUM <= 10;","exampleSqlTarget":"SELECT * FROM users LIMIT 10;"},
    {"code":"O2GD2-SYN-002","name":"DUAL → 移除","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"FROM DUAL","replacementPattern":"","description":"GoldenDB 不需要 DUAL 表","exampleSqlSource":"SELECT SYSDATE FROM DUAL;","exampleSqlTarget":"SELECT NOW();"},
    {"code":"O2GD2-SYN-003","name":"序列 → AUTO_INCREMENT","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"${seq}.NEXTVAL","replacementPattern":"AUTO_INCREMENT","description":"Oracle 序列替换为 GoldenDB AUTO_INCREMENT","exampleSqlSource":"INSERT INTO t (id) VALUES (myseq.NEXTVAL);","exampleSqlTarget":"CREATE TABLE t (id INT AUTO_INCREMENT PRIMARY KEY);"},
    {"code":"O2GD2-SYN-004","name":"外连接(+) → JOIN","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"(+)","replacementPattern":"LEFT JOIN","description":"Oracle (+) 外连接替换为标准 LEFT/RIGHT JOIN","exampleSqlSource":"SELECT * FROM a, b WHERE a.id=b.id(+);","exampleSqlTarget":"SELECT * FROM a LEFT JOIN b ON a.id=b.id;"},
    {"code":"O2GD2-SYN-005","name":"MERGE INTO → REPLACE INTO","category":"SYNTAX","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"MERGE INTO","replacementPattern":"REPLACE INTO","description":"Oracle MERGE INTO 替换为 REPLACE INTO 或 INSERT ON DUPLICATE KEY UPDATE","exampleSqlSource":"MERGE INTO t USING dual ON (t.id=1) WHEN MATCHED THEN UPDATE SET name='A';","exampleSqlTarget":"INSERT INTO t (id,name) VALUES (1,'A') ON DUPLICATE KEY UPDATE name='A';"},
    {"code":"O2GD2-DT-001","name":"VARCHAR2 → VARCHAR","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"VARCHAR2","replacementPattern":"VARCHAR","description":"Oracle VARCHAR2 替换为 VARCHAR","exampleSqlSource":"CREATE TABLE t (name VARCHAR2(100));","exampleSqlTarget":"CREATE TABLE t (name VARCHAR(100));"},
    {"code":"O2GD2-DT-002","name":"NUMBER → DECIMAL","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"NUMBER","replacementPattern":"DECIMAL","description":"Oracle NUMBER 替换为 DECIMAL","exampleSqlSource":"CREATE TABLE t (amount NUMBER(10,2));","exampleSqlTarget":"CREATE TABLE t (amount DECIMAL(10,2));"},
    {"code":"O2GD2-DT-003","name":"CLOB → LONGTEXT","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"CLOB","replacementPattern":"LONGTEXT","description":"Oracle CLOB 替换为 LONGTEXT","exampleSqlSource":"CREATE TABLE t (content CLOB);","exampleSqlTarget":"CREATE TABLE t (content LONGTEXT);"},
    {"code":"O2GD2-DT-004","name":"DATE → DATETIME","category":"DATATYPE","severity":"ERROR","patternType":"DATATYPE","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"DATE","replacementPattern":"DATETIME","description":"Oracle DATE(含时间) 替换为 DATETIME","exampleSqlSource":"CREATE TABLE t (created_at DATE);","exampleSqlTarget":"CREATE TABLE t (created_at DATETIME);"},
    {"code":"O2GD2-PL-001","name":"PL/SQL → MySQL 存储过程","category":"DDL","severity":"ERROR","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"CREATE OR REPLACE PROCEDURE","replacementPattern":"CREATE PROCEDURE","description":"Oracle PL/SQL 需完全重写为 MySQL/GoldenDB 存储过程语法","exampleSqlSource":"CREATE OR REPLACE PROCEDURE p1 AS BEGIN NULL; END;","exampleSqlTarget":"CREATE PROCEDURE p1() BEGIN /* 需重写 */ END;"},
    {"code":"O2GD2-DDL-001","name":"TABLESPACE/STORAGE → 移除","category":"DDL","severity":"WARNING","patternType":"SYNTAX","sourceDbType":"ORACLE","targetDbType":"GOLDENDB","matchPattern":"TABLESPACE ${name}","replacementPattern":"","description":"Oracle TABLESPACE/STORAGE 在 GoldenDB 中不存在，需移除","exampleSqlSource":"CREATE TABLE t (id INT) TABLESPACE users;","exampleSqlTarget":"CREATE TABLE t (id INT);"}
  ]
}
