<idea-plugin>
    <id>com.dma.idea</id>
    <name>Database Migration Assistant</name>
    <vendor email="arvin-lk@github.com" url="https://github.com/Arvin-LK/dma">DMA Team</vendor>
    <version>1.1.0</version>

    <description><![CDATA[
        数据库迁移与兼容性分析工具。
        支持 MySQL/Oracle/SQLServer → PostgreSQL/GaussDB/达梦 迁移检测。
        在 Java 字符串和 SQL 文件中实时检测兼容性问题并提供修复建议。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- SQL 兼容性检测 -->
        <localInspection
            groupName="DMA"
            displayName="SQL 兼容性检测"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.dma.idea.inspection.SqlCompatibilityInspection"
            language="JAVA"/>
    </extensions>
</idea-plugin>
