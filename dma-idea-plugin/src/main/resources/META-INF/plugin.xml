<idea-plugin>
    <id>com.dma.idea</id>
    <name>Database Migration Assistant</name>
    <vendor email="arvin-lk@github.com" url="https://github.com/Arvin-LK/dma">DMA Team</vendor>
    <version>1.1.0</version>

    <!-- 兼容 IDEA 2021.1 及以上所有版本 -->
    <idea-version since-build="211" until-build="999.*"/>

    <description><![CDATA[
        DMA — 数据库迁移兼容性检测。
        实时检查 Java 字符串中的 SQL 语句，支持 MySQL/Oracle/SQLServer → PG/GaussDB/达梦。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <localInspection
            groupName="DMA"
            displayName="SQL 兼容性检测"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.dma.idea.inspection.SqlCompatibilityInspection"/>
    </extensions>
</idea-plugin>
